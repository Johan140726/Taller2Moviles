<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorFondoApplication"
    tools:context=".Activities.SplashActivity">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/LogoAplicativo"
            android:layout_width="300dp"
            android:layout_height="300dp"
            app:srcCompat="@mipmap/logo_application_foreground" />

        <TextView
            android:id="@+id/nombreApplicationSplash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-30dp"
            android:fontFamily="@font/tiro_bangla_italic"
            android:text="@string/nombreApplicationSplash"
            android:textColor="@color/colorLetraSplash"
            android:textSize="48sp"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:id="@+id/firmaSplash"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:fontFamily="@font/tiro_bangla_italic"
        android:text="@string/firmaSplash"
        android:textColor="@color/colorLetraSplash"
        android:textSize="24sp"
        android:textStyle="bold" />

</LinearLayout>