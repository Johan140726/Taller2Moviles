<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorFondoApplication"
    android:gravity="center_horizontal"
    tools:context=".Activities.RegistroActivity">

    <TextView
        android:id="@+id/tituloRegistro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/tiro_bangla_italic"
        android:text="@string/tituloRegistro"
        android:textColor="@color/colorLetraSplash"
        android:textSize="48sp"
        android:textStyle="bold"
        />

    <EditText
        android:id="@+id/campoNombres"
        android:layout_width="342dp"
        android:layout_height="43dp"
        android:background="@drawable/style_edit_text"
        android:ems="10"
        android:hint="@string/campoNombreRegistro"
        android:inputType="textPersonName"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:textColor="@color/black"
        android:textColorHint="@color/colorhint"
        android:layout_marginVertical="5dp"/>

    <EditText
        android:id="@+id/campoApellidos"
        android:layout_width="342dp"
        android:layout_height="43dp"
        android:background="@drawable/style_edit_text"
        android:ems="10"
        android:hint="@string/campoApellidosRegistro"
        android:inputType="textPersonName"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:textColor="@color/black"
        android:textColorHint="@color/colorhint"
        android:layout_marginVertical="5dp"
       />

    <EditText
        android:id="@+id/campoCorreo"
        android:layout_width="342dp"
        android:layout_height="43dp"
        android:background="@drawable/style_edit_text"
        android:ems="10"
        android:hint="@string/campoCorreoRegistro"
        android:inputType="textEmailAddress"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:textColor="@color/black"
        android:textColorHint="@color/colorhint"
        android:layout_marginVertical="5dp"
        />

    <EditText
        android:id="@+id/campoContra"
        android:layout_width="342dp"
        android:layout_height="43dp"
        android:background="@drawable/style_edit_text"
        android:ems="10"
        android:hint="@string/campoContraRegistro"
        android:inputType="textVisiblePassword"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:textColor="@color/black"
        android:textColorHint="@color/colorhint"
        android:layout_marginVertical="5dp"
        />

    <EditText
        android:id="@+id/campoRepetirContra"
        android:layout_width="342dp"
        android:layout_height="43dp"
        android:background="@drawable/style_edit_text"
        android:ems="10"
        android:hint="@string/campoRepetirContra"
        android:inputType="textVisiblePassword"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:textColor="@color/black"
        android:textColorHint="@color/colorhint"
        android:layout_marginVertical="5dp"
        />

    <CheckBox
        android:id="@+id/chkTerminos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/tiro_bangla_italic"
        android:text="Acepto los Términos y Condiciones"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/botonRegistrate"
        android:layout_width="288dp"
        android:layout_height="65dp"
        android:layout_marginTop="25dp"
        android:backgroundTint="@color/white"
        android:text="@string/botonRegistrate"
        android:textColor="@color/black"
        android:textSize="34sp"
        android:textStyle="bold" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="15dp">

        <TextView
            android:id="@+id/tvPregunta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tiro_bangla_italic"
            android:text="¿Ya tienes cuenta?"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/tiro_bangla_italic"
            android:text="Inicia sesión"
            android:textColor="@color/azul_login"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>










</LinearLayout>